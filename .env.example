# OpenAI-compatible API base URL (the ComfyUI wrapper endpoint)
IMAGE_API_BASE_URL=http://127.0.0.1:5000

# Default model to use for both generate and edit tools
IMAGE_API_MODEL=flux-2-klein-4b

# Optional Bearer token for the API
IMAGE_API_KEY=sk-your-api-key-here

# Per-request timeout in seconds (default 600 — image gen is slow)
IMAGE_API_TIMEOUT=600
